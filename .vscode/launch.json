{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug NextJS",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "ready on http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Debug NextJS (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack://_N_E/./src/*": "${workspaceFolder}/frontend/src/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug NextJS Full",
      "configurations": ["Debug NextJS", "Debug NextJS (Chrome)"]
    }
  ]
}
